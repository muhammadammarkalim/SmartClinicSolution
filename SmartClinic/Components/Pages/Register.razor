@page "/register"
@layout SmartClinic.Components.Layout.MainLayout
@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations
@using SmartClinic.Models
@inject UserManager<AppUser> UserManager
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Register - MediBook</PageTitle>

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg border-0 p-4" style="max-width: 460px; width: 100%; border-radius: 16px;">
        
        <div class="text-center mb-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-2" style="width: 55px; height: 55px; background-color: #1F4E79 !important;">
                <span class="fs-3">📝</span>
            </div>
            <h3 class="fw-bold mt-1" style="color: #1F4E79;">Create Account</h3>
            <p class="text-muted small">Join MediBook Clinic Platform as a Patient</p>
        </div>

        @if (errorMessages != null && errorMessages.Any())
        {
            <div class="alert alert-danger small py-2" role="alert">
                <ul class="mb-0 ps-3">
                    @foreach (var err in errorMessages)
                    {
                        <li>@err</li>
                    }
                </ul>
            </div>
        }

        <EditForm Model="registerModel" OnValidSubmit="HandleRegistration" FormName="patientRegisterForm" method="post">
            <DataAnnotationsValidator />
            <AntiforgeryToken />

            <div class="mb-3">
                <label class="form-label small text-secondary fw-bold">Full Name</label>
                <InputText @bind-Value="registerModel.FullName" class="form-control py-2" placeholder="Enter your full name" />
                <ValidationMessage For="() => registerModel.FullName" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label small text-secondary fw-bold">Email Address</label>
                <InputText @bind-Value="registerModel.Email" class="form-control py-2" placeholder="name@example.com" type="email" />
                <ValidationMessage For="() => registerModel.Email" class="text-danger small" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-secondary fw-bold">Password</label>
                    <InputText @bind-Value="registerModel.Password" class="form-control py-2" placeholder="••••••" type="password" />
                    <ValidationMessage For="() => registerModel.Password" class="text-danger small" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-secondary fw-bold">Confirm Password</label>
                    <InputText @bind-Value="registerModel.ConfirmPassword" class="form-control py-2" placeholder="••••••" type="password" />
                    <ValidationMessage For="() => registerModel.ConfirmPassword" class="text-danger small" />
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="termsCheck" required />
                <label class="form-check-label small text-muted" for="termsCheck">
                    I agree to the clinic service regulations and privacy terms.
                </label>
            </div>

            <button type="submit" class="btn text-white w-100 py-2 fw-bold mb-3 shadow-sm btn-register" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Creating Profile...</span>
                }
                else
                {
                    <span>Register Account</span>
                }
            </button>
        </EditForm>

        <div class="text-center mt-1">
            <p class="small text-muted mb-0">Already have an account? <a href="login" class="fw-bold text-decoration-none" style="color: #2E75B6;">Login here</a></p>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #F5F8FF !important;
    }
    .btn-register {
        background-color: #1F4E79;
        border-radius: 8px;
        transition: background-color 0.2s ease;
    }
    .btn-register:hover {
        background-color: #2E75B6;
    }
    .form-control:focus {
        border-color: #2E75B6;
        box-shadow: 0 0 0 0.25rem rgba(46, 117, 182, 0.15);
    }
</style>

@code {
    [SupplyParameterFromForm(FormName = "patientRegisterForm")]
    private RegisterInputModel registerModel { get; set; } = new();
    
    private List<string>? errorMessages;
    private bool isProcessing = false;

    private async Task HandleRegistration()
    {
        isProcessing = true;
        errorMessages = null;

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessages = new List<string> { "The password and confirmation password do not match." };
            isProcessing = false;
            return;
        }

        try
        {
            var cleanEmail = registerModel.Email.Trim();
            var newUser = new AppUser
            {
                UserName = cleanEmail,
                Email = cleanEmail,
                Name = registerModel.FullName,
                Role = "Patient",
                CreatedAt = DateTime.Now
            };

            var result = await UserManager.CreateAsync(newUser, registerModel.Password);

            if (result.Succeeded)
            {
                await UserManager.AddToRoleAsync(newUser, "Patient");
                
                // CRITICAL BULLETPROOF FIX: 
                // Navigate to the pure HTTP bridge endpoint to sign the user in safely and drop cookies.
                // This completely bypasses the interactive circuit thread conflict.
                NavManager.NavigateTo($"/api/auth/register-login?userId={newUser.Id}", forceLoad: true);
            }
            else
            {
                errorMessages = result.Errors.Select(e => e.Description).ToList();
                isProcessing = false;
            }
        }
        catch (Exception ex)
        {
            errorMessages = new List<string> { "An error occurred during account submission: " + ex.Message };
            isProcessing = false;
        }
    }

    public class RegisterInputModel
    {
        [Required(ErrorMessage = "Full Name field is required.")]
        [StringLength(100, ErrorMessage = "Name cannot exceed 100 characters.")]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is required.")]
        [EmailAddress(ErrorMessage = "Please supply a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password configuration is required.")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters long.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password entry.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}