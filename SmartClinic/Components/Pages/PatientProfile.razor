@page "/profile"
@layout SmartClinic.Components.Layout.MainLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Patient")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SmartClinic.Data
@using SmartClinic.Models
@using System.Security.Claims

@inject ApplicationDbContext DbContext
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<PageTitle>My Profile - SmartClinic</PageTitle>

<div class="d-flex" style="min-height:100vh; background:#F3F4F6;">

    <!-- Sidebar -->
    <div class="sc-sidebar d-none d-lg-flex flex-column">
        <div class="sc-sidebar-brand">
            <div class="brand-name">SmartClinic</div>
            <div class="brand-sub">Patient Portal</div>
        </div>
        <div class="sc-sidebar-user">
            <div class="user-name">@currentUser?.Name</div>
            <div class="user-role">Patient</div>
        </div>
        <nav class="sc-nav">
            <a href="/dashboard" class="sc-nav-link"><i class="bi bi-grid"></i> Dashboard</a>
            <a href="/doctors" class="sc-nav-link"><i class="bi bi-search-heart"></i> Find Doctors</a>
            <a href="/symptom-checker" class="sc-nav-link"><i class="bi bi-cpu"></i> Symptom Checker</a>
            <div class="sc-nav-divider border-top mx-3 my-1"></div>
            <a href="/appointments" class="sc-nav-link"><i class="bi bi-calendar3"></i> My Appointments</a>
            <a href="/timeline" class="sc-nav-link"><i class="bi bi-clock-history"></i> Health Timeline</a>
            <a href="/prescriptions" class="sc-nav-link"><i class="bi bi-capsule"></i> My Prescriptions</a>
            <a href="/profile" class="sc-nav-link active"><i class="bi bi-person-circle"></i> My Profile</a>
            <div class="sc-nav-divider border-top mx-3 my-1"></div>
            <form action="Account/Logout" method="post" class="m-0 p-0">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="" />
                <button type="submit" class="sc-logout-btn"><i class="bi bi-box-arrow-left"></i> Logout</button>
            </form>
        </nav>
    </div>

    <!-- Content -->
    <div class="sc-main">
        <div class="sc-topbar">
            <div>
                <h1 class="page-title">My Profile</h1>
                <p class="page-sub">Manage your personal and medical information</p>
            </div>
            @if (!isEditing)
            {
                <button class="sc-btn sc-btn-primary" @onclick="StartEdit">
                    <i class="bi bi-pencil"></i> Edit Profile
                </button>
            }
        </div>

        <div class="sc-content">

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="sc-alert sc-alert-success mb-4">
                    <i class="bi bi-check-circle me-2"></i>@successMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="sc-alert sc-alert-danger mb-4">
                    <i class="bi bi-exclamation-circle me-2"></i>@errorMessage
                </div>
            }

            @if (currentUser == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted mt-3">Loading profile...</p>
                </div>
            }
            else if (!isEditing)
            {
                <!-- VIEW MODE -->
                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="sc-profile-card">
                            <div class="sc-profile-header">
                                <div class="sc-avatar sc-avatar-xl">
                                    @if (!string.IsNullOrEmpty(currentUser.ProfileImage))
                                    {
                                        <img src="@currentUser.ProfileImage" alt="Profile" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(currentUser.Name)</span>
                                    }
                                </div>
                                <div>
                                    <h3 style="color:#fff; font-size:20px; font-weight:700; margin:0;">@currentUser.Name</h3>
                                    <div style="color:rgba(255,255,255,0.65); font-size:13px; margin-top:4px;">@currentUser.Email</div>
                                    @if (!string.IsNullOrEmpty(currentUser.BloodGroup))
                                    {
                                        <span class="sc-badge sc-badge-red mt-2 d-inline-block">
                                            <i class="bi bi-droplet-fill me-1"></i> @currentUser.BloodGroup
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="sc-profile-body">
                                <div class="sc-profile-field">
                                    <div class="sc-profile-field-label">Member Since</div>
                                    <div class="sc-profile-field-value">@currentUser.CreatedAt.ToString("MMMM dd, yyyy")</div>
                                </div>
                                @if (currentUser.DateOfBirth.HasValue)
                                {
                                    <div class="sc-profile-field">
                                        <div class="sc-profile-field-label">Age</div>
                                        <div class="sc-profile-field-value">@CalculateAge(currentUser.DateOfBirth.Value) years old</div>
                                    </div>
                                }
                                <div class="sc-profile-field">
                                    <div class="sc-profile-field-label">Account Status</div>
                                    <div><span class="sc-badge sc-badge-green">Active</span></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="sc-card mb-4">
                            <div class="sc-card-header">
                                <h2 class="sc-card-title"><i class="bi bi-person me-2 text-primary"></i>Personal Information</h2>
                            </div>
                            <div class="sc-card-body">
                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Full Name</div>
                                        <div class="sc-profile-field-value">@currentUser.Name</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Email Address</div>
                                        <div class="sc-profile-field-value">@currentUser.Email</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Phone Number</div>
                                        <div class="sc-profile-field-value">@(currentUser.PhoneNumber ?? "Not provided")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Gender</div>
                                        <div class="sc-profile-field-value">@(currentUser.Gender ?? "Not provided")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Date of Birth</div>
                                        <div class="sc-profile-field-value">@(currentUser.DateOfBirth?.ToString("MMMM dd, yyyy") ?? "Not provided")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Blood Group</div>
                                        <div class="sc-profile-field-value">@(currentUser.BloodGroup ?? "Not provided")</div>
                                    </div>
                                    <div class="col-12">
                                        <div class="sc-profile-field-label">Address</div>
                                        <div class="sc-profile-field-value">@(currentUser.Address ?? "Not provided")</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="sc-card">
                            <div class="sc-card-header">
                                <h2 class="sc-card-title"><i class="bi bi-shield-plus me-2 text-danger"></i>Emergency Contact</h2>
                            </div>
                            <div class="sc-card-body">
                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Contact Name</div>
                                        <div class="sc-profile-field-value">@(currentUser.EmergencyContact ?? "Not provided")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="sc-profile-field-label">Contact Phone</div>
                                        <div class="sc-profile-field-value">@(currentUser.EmergencyPhone ?? "Not provided")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- EDIT MODE -->
                <div class="sc-card">
                    <div class="sc-card-header">
                        <h2 class="sc-card-title">Edit Profile Information</h2>
                        <button class="sc-btn sc-btn-outline sc-btn-sm" @onclick="CancelEdit">Cancel</button>
                    </div>
                    <div class="sc-card-body">
                        <div class="sc-form-section">Profile Photo</div>
                        <div class="sc-form-group">
                            <label class="sc-form-label">Profile Image URL</label>
                            <input class="sc-form-control" placeholder="https://example.com/your-photo.jpg"
                                   @bind="editModel.ProfileImage" />
                            <div style="font-size:12px; color:#6B7280; margin-top:5px;">
                                Enter a direct image URL (JPG, PNG). Leave blank to use initials.
                            </div>
                            @if (!string.IsNullOrEmpty(editModel.ProfileImage))
                            {
                                <div class="mt-3 d-flex align-items-center gap-3">
                                    <div class="sc-avatar sc-avatar-lg">
                                        <img src="@editModel.ProfileImage" alt="Preview" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                                    </div>
                                    <span style="font-size:13px; color:#6B7280;">Preview</span>
                                </div>
                            }
                        </div>

                        <div class="sc-form-section">Personal Details</div>
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Full Name</label>
                                    <input class="sc-form-control" @bind="editModel.Name" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Phone Number</label>
                                    <input class="sc-form-control" @bind="editModel.PhoneNumber" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Date of Birth</label>
                                    <input type="date" class="sc-form-control" @bind="editModel.DateOfBirth" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Gender</label>
                                    <select class="sc-form-control sc-form-select" @bind="editModel.Gender">
                                        <option value="">Select Gender</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Blood Group</label>
                                    <select class="sc-form-control sc-form-select" @bind="editModel.BloodGroup">
                                        <option value="">Select Blood Group</option>
                                        <option value="A+">A+</option>
                                        <option value="A-">A-</option>
                                        <option value="B+">B+</option>
                                        <option value="B-">B-</option>
                                        <option value="AB+">AB+</option>
                                        <option value="AB-">AB-</option>
                                        <option value="O+">O+</option>
                                        <option value="O-">O-</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Home Address</label>
                                    <textarea class="sc-form-control" rows="2" @bind="editModel.Address"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="sc-form-section">Emergency Contact</div>
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Contact Name</label>
                                    <input class="sc-form-control" placeholder="Full name" @bind="editModel.EmergencyContact" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="sc-form-group">
                                    <label class="sc-form-label">Contact Phone</label>
                                    <input class="sc-form-control" placeholder="+92 300 0000000" @bind="editModel.EmergencyPhone" />
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 justify-content-end">
                            <button class="sc-btn sc-btn-outline" @onclick="CancelEdit">Cancel</button>
                            <button class="sc-btn sc-btn-primary" @onclick="SaveProfile" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i>
                                    <span>Save Changes</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private AppUser? currentUser;
    private bool isEditing = false;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;

    private ProfileEditModel editModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId != null)
        {
            currentUser = await DbContext.Users.FindAsync(userId);
        }
    }

    private void StartEdit()
    {
        if (currentUser == null) return;
        editModel = new ProfileEditModel
        {
            Name = currentUser.Name,
            PhoneNumber = currentUser.PhoneNumber,
            DateOfBirth = currentUser.DateOfBirth,
            Gender = currentUser.Gender,
            BloodGroup = currentUser.BloodGroup,
            Address = currentUser.Address,
            EmergencyContact = currentUser.EmergencyContact,
            EmergencyPhone = currentUser.EmergencyPhone,
            ProfileImage = currentUser.ProfileImage
        };
        isEditing = true;
        successMessage = null;
        errorMessage = null;
    }

    private void CancelEdit()
    {
        isEditing = false;
        errorMessage = null;
    }

    private async Task SaveProfile()
    {
        if (currentUser == null) return;
        isSaving = true;
        errorMessage = null;

        try
        {
            currentUser.Name = editModel.Name?.Trim() ?? currentUser.Name;
            currentUser.PhoneNumber = editModel.PhoneNumber;
            currentUser.DateOfBirth = editModel.DateOfBirth;
            currentUser.Gender = editModel.Gender;
            currentUser.BloodGroup = editModel.BloodGroup;
            currentUser.Address = editModel.Address;
            currentUser.EmergencyContact = editModel.EmergencyContact;
            currentUser.EmergencyPhone = editModel.EmergencyPhone;
            currentUser.ProfileImage = editModel.ProfileImage;

            await DbContext.SaveChangesAsync();
            isEditing = false;
            successMessage = "Profile updated successfully.";
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to save changes. Please try again.";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "P";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name[0].ToString().ToUpper();
    }

    private int CalculateAge(DateTime dob)
    {
        var today = DateTime.Today;
        var age = today.Year - dob.Year;
        if (dob.Date > today.AddYears(-age)) age--;
        return age;
    }

    private class ProfileEditModel
    {
        public string? Name { get; set; }
        public string? PhoneNumber { get; set; }
        public DateTime? DateOfBirth { get; set; }
        public string? Gender { get; set; }
        public string? BloodGroup { get; set; }
        public string? Address { get; set; }
        public string? EmergencyContact { get; set; }
        public string? EmergencyPhone { get; set; }
        public string? ProfileImage { get; set; }
    }
}
