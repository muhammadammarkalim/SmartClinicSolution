@page "/doctor/dashboard"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Doctor")]

@using Microsoft.AspNetCore.Authorization
@using SmartClinic.Models
@using SmartClinic.Data
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity

@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<AppUser> UserManager

<PageTitle>Doctor Dashboard - SmartClinic</PageTitle>

<div class="d-flex" style="min-height:100vh; background:#F3F4F6;">

    <!-- Sidebar -->
    <div class="sc-sidebar d-none d-lg-flex flex-column">
        <div class="sc-sidebar-brand">
            <div class="brand-name">SmartClinic</div>
            <div class="brand-sub">Doctor Portal</div>
        </div>
        <div class="sc-sidebar-user d-flex align-items-center gap-3">
            <div class="sc-avatar">
                @if (!string.IsNullOrEmpty(doctorPhoto))
                {
                    <img src="@doctorPhoto" alt="Doctor" />
                }
                else
                {
                    <i class="bi bi-person-fill" style="font-size:18px;"></i>
                }
            </div>
            <div>
                <div class="user-name">Dr. @doctorName</div>
                <div class="user-role">@doctorSpecialty</div>
            </div>
        </div>
        <nav class="sc-nav">
            <a href="/doctor/dashboard" class="sc-nav-link active"><i class="bi bi-grid"></i> Dashboard</a>
            <a href="/doctor/schedule" class="sc-nav-link"><i class="bi bi-calendar3"></i> My Schedule</a>
            <a href="/doctor/patients" class="sc-nav-link"><i class="bi bi-people"></i> My Patients</a>
            <div class="sc-nav-divider border-top mx-3 my-1"></div>
            <form action="Account/Logout" method="post" class="m-0 p-0">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="" />
                <button type="submit" class="sc-logout-btn"><i class="bi bi-box-arrow-left"></i> Logout</button>
            </form>
        </nav>
    </div>

    <!-- Main -->
    <div class="sc-main">
        <div class="sc-topbar">
            <div>
                <h1 class="page-title">Good @GetGreeting(), Dr. @doctorName</h1>
                <p class="page-sub">@DateTime.Now.ToString("dddd, d MMMM yyyy") &mdash; @todayAppointments.Count appointment(s) today</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (isAvailable)
                {
                    <span class="sc-badge sc-badge-green"><i class="bi bi-circle-fill me-1" style="font-size:8px;"></i> Available</span>
                }
                else
                {
                    <span class="sc-badge sc-badge-gray"><i class="bi bi-circle me-1" style="font-size:8px;"></i> Unavailable</span>
                }
            </div>
        </div>

        <div class="sc-content">

            <!-- Stats -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-xl-3">
                    <div class="sc-stat">
                        <div class="sc-stat-icon blue"><i class="bi bi-calendar-day"></i></div>
                        <div>
                            <div class="sc-stat-value">@todayAppointments.Count</div>
                            <div class="sc-stat-label">Today's Patients</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="sc-stat">
                        <div class="sc-stat-icon green"><i class="bi bi-check-circle"></i></div>
                        <div>
                            <div class="sc-stat-value">@todayAppointments.Count(a => a.Status == "Completed")</div>
                            <div class="sc-stat-label">Completed</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="sc-stat">
                        <div class="sc-stat-icon amber"><i class="bi bi-hourglass-split"></i></div>
                        <div>
                            <div class="sc-stat-value">@todayAppointments.Count(a => a.Status == "Booked" || a.Status == "Confirmed")</div>
                            <div class="sc-stat-label">Pending</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="sc-stat">
                        <div class="sc-stat-icon" style="background:#FFF7FF; color:#7C3AED;"><i class="bi bi-star-fill"></i></div>
                        <div>
                            <div class="sc-stat-value">@doctorRating.ToString("0.0")</div>
                            <div class="sc-stat-label">Rating</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Today's Queue -->
            <div class="sc-card mb-4">
                <div class="sc-card-header">
                    <h2 class="sc-card-title"><i class="bi bi-people me-2 text-primary"></i>Today's Patient Queue</h2>
                    <a href="/doctor/schedule" class="sc-btn sc-btn-outline sc-btn-sm">Full Schedule</a>
                </div>
                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" style="width:24px;height:24px;" role="status"></div>
                    </div>
                }
                else if (!todayAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-check" style="font-size:36px; color:#D1D5DB;"></i>
                        <p class="text-muted mt-3 mb-0" style="font-size:14px;">No appointments scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sc-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Patient</th>
                                    <th>Blood Group</th>
                                    <th>Urgency</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in todayAppointments.OrderBy(a => a.AppointmentDateTime))
                                {
                                    <tr>
                                        <td>
                                            <span style="font-weight:600; font-size:13.5px;">@appt.AppointmentDateTime.ToString("hh:mm tt")</span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="sc-avatar" style="width:36px;height:36px;font-size:13px;">
                                                    @if (!string.IsNullOrEmpty((appt.Patient as AppUser)?.ProfileImage))
                                                    {
                                                        <img src="@((appt.Patient as AppUser)?.ProfileImage)" alt="Patient" />
                                                    }
                                                    else
                                                    {
                                                        <span>@GetInitials(appt.Patient?.Name ?? "P")</span>
                                                    }
                                                </div>
                                                <div>
                                                    <div style="font-size:13.5px; font-weight:600;">@appt.Patient?.Name</div>
                                                    @if (!string.IsNullOrEmpty(appt.PatientNotes))
                                                    {
                                                        <div class="text-truncate" style="font-size:11.5px; color:#6B7280; max-width:160px;">@appt.PatientNotes</div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @{
                                                var patientUser = appt.Patient as AppUser;
                                                var bg = patientUser?.BloodGroup;
                                            }
                                            @if (!string.IsNullOrEmpty(bg))
                                            {
                                                <span class="sc-badge sc-badge-red">@bg</span>
                                            }
                                            else
                                            {
                                                <span style="color:#9CA3AF; font-size:12px;">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="sc-badge @(appt.Urgency == "Urgent" ? "sc-badge-red" : appt.Urgency == "Moderate" ? "sc-badge-amber" : "sc-badge-green")">
                                                @appt.Urgency
                                            </span>
                                        </td>
                                        <td>
                                            <span class="sc-badge @GetStatusBadge(appt.Status)">@appt.Status</span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                @if (appt.Status == "Booked" || appt.Status == "Confirmed")
                                                {
                                                    <button class="sc-btn sc-btn-primary sc-btn-sm"
                                                            @onclick="() => StartConsultation(appt.AppointmentID)">
                                                        <i class="bi bi-play-fill"></i> Start
                                                    </button>
                                                }
                                                <a href="/doctor/patient-history/@appt.PatientID"
                                                   class="sc-btn sc-btn-outline sc-btn-sm">
                                                    <i class="bi bi-clock-history"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Upcoming appointments (next 7 days) -->
            @if (upcomingAppointments.Any())
            {
                <div class="sc-card">
                    <div class="sc-card-header">
                        <h2 class="sc-card-title"><i class="bi bi-calendar-week me-2 text-primary"></i>Upcoming (Next 7 Days)</h2>
                    </div>
                    <div class="table-responsive">
                        <table class="sc-table">
                            <thead>
                                <tr>
                                    <th>Date &amp; Time</th>
                                    <th>Patient</th>
                                    <th>Urgency</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in upcomingAppointments.Take(10))
                                {
                                    <tr>
                                        <td style="font-size:13.5px;">@appt.AppointmentDateTime.ToString("ddd, d MMM – hh:mm tt")</td>
                                        <td style="font-weight:600; font-size:13.5px;">@appt.Patient?.Name</td>
                                        <td>
                                            <span class="sc-badge @(appt.Urgency == "Urgent" ? "sc-badge-red" : appt.Urgency == "Moderate" ? "sc-badge-amber" : "sc-badge-green")">
                                                @appt.Urgency
                                            </span>
                                        </td>
                                        <td><span class="sc-badge @GetStatusBadge(appt.Status)">@appt.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@code {
    private string doctorName = "Doctor";
    private string doctorSpecialty = "";
    private string? doctorPhoto;
    private double doctorRating = 0.0;
    private bool isAvailable = true;
    private bool isLoading = true;

    private List<Appointment> todayAppointments = new();
    private List<Appointment> upcomingAppointments = new();
    private int totalCompletedCount = 0;
    private int totalPendingCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user != null)
        {
            if (user.IsFirstLogin)
            {
                NavManager.NavigateTo("/change-password");
                return;
            }

            doctorName = user.Name;

            var doctor = await DbContext.Doctors
                .FirstOrDefaultAsync(d => d.UserID == user.Id && !d.IsDeleted);

            if (doctor != null)
            {
                doctorSpecialty = doctor.Specialty;
                doctorPhoto = doctor.Photo;
                doctorRating = doctor.Rating;
                isAvailable = doctor.IsAvailable;

                    var today = DateTime.Today;
                    var allAppts = await DbContext.Appointments
                        .Include(a => a.Patient)
                        .Where(a => a.DoctorID == doctor.DoctorID && a.Status != "Cancelled")
                        .OrderBy(a => a.AppointmentDateTime)
                        .ToListAsync();

                    // Today's appointments
                    todayAppointments = allAppts
                        .Where(a => a.AppointmentDateTime.Date == today)
                        .ToList();

                    // Upcoming next 7 days
                    upcomingAppointments = allAppts
                        .Where(a => a.AppointmentDateTime.Date > today && a.AppointmentDateTime.Date <= today.AddDays(7))
                        .ToList();

                    // Totals across all appointments for this doctor - fetch fresh counts from DB
                    totalCompletedCount = await DbContext.Appointments
                        .CountAsync(a => a.DoctorID == doctor.DoctorID && a.Status == "Completed");

                    totalPendingCount = await DbContext.Appointments
                        .CountAsync(a => a.DoctorID == doctor.DoctorID && (a.Status == "Booked" || a.Status == "Confirmed" || a.Status == "In Progress"));
            }
        }

        isLoading = false;
    }

    private void StartConsultation(int id) => NavManager.NavigateTo($"/doctor/consultation/{id}");

    private string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        return hour < 12 ? "morning" : hour < 17 ? "afternoon" : "evening";
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name[0].ToString().ToUpper();
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Completed" => "sc-badge-green",
        "Cancelled" => "sc-badge-gray",
        "Confirmed" => "sc-badge-blue",
        "Booked" => "sc-badge-blue",
        _ => "sc-badge-amber"
    };
}
