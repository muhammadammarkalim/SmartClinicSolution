@page "/change-password"
@rendermode InteractiveServer
@inject UserManager<AppUser> UserManager
@using Microsoft.AspNetCore.Identity
@inject NavigationManager NavManager

<div class="card p-4 mx-auto" style="max-width: 400px;">
    <h3>Set Your Permanent Password</h3>
    <input type="password" class="form-control mb-2" @bind-value="newPassword" @bind-value:event="oninput" placeholder="New Password" />
    <div class="mb-2 small text-muted">Password must be at least 8 characters.</div>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger py-2">@errorMessage</div>
    }
    <button class="btn btn-primary w-100" @onclick="UpdatePassword" disabled="@(isSubmitting || string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 8)">Update & Login</button>
</div>

@code {
    private string newPassword;
    private string errorMessage = string.Empty;
    private bool isSubmitting = false;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; }

    private async Task UpdatePassword()
    {
        errorMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 8)
        {
            errorMessage = "Please enter a password of at least 8 characters.";
            return;
        }

        isSubmitting = true;
        // 1. Get the authentication state
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = authState.User;

        // 2. Now 'userPrincipal' exists and can be used to get the user
        var user = await UserManager.GetUserAsync(userPrincipal);
        
        if (user != null)
        {
            try
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var result = await UserManager.ResetPasswordAsync(user, token, newPassword);
                if (!result.Succeeded)
                {
                    errorMessage = string.Join("; ", result.Errors.Select(e => e.Description));
                    return;
                }

                user.IsFirstLogin = false;
                var updateResult = await UserManager.UpdateAsync(user);
                if (!updateResult.Succeeded)
                {
                    errorMessage = string.Join("; ", updateResult.Errors.Select(e => e.Description));
                    return;
                }

                // Success - navigate to dashboard
                NavManager.NavigateTo("/doctor/dashboard", true);
            }
            catch (Exception ex)
            {
                errorMessage = "Failed to update password: " + ex.GetBaseException().Message;
            }
            finally
            {
                isSubmitting = false;
            }
        }
        else
        {
            isSubmitting = false;
            errorMessage = "User session not found. Please login again.";
        }
    }
}