@inherits LayoutComponentBase
@using SmartClinic.Components.Layout

<div class="page d-flex flex-column min-vh-100">
    <NavMenu />

    <main class="flex-grow-1 py-4">
        <div class="container-fluid px-4">
            @Body
        </div>
    </main>

    <footer class="bg-white border-top text-center py-3 text-muted small mt-auto">
        <div class="container">
            &copy; @DateTime.Now.Year MediBook Clinic Booking System — University Semester Project
        </div>
    </footer>
</div>

<div id="blazor-error-ui" class="alert alert-warning position-fixed bottom-0 start-0 m-3 shadow" style="display: none; z-index: 1050;">
    An unhandled error has occurred.
    <a href="." class="reload btn btn-sm btn-outline-warning ms-2">Reload</a>
    <a class="dismiss close position-absolute top-0 end-0 p-1 text-decoration-none">✕</a>
</div>